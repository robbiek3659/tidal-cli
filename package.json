{
  "name": "@lucaperret/tidal-cli",
  "version": "1.1.2",
  "description": "CLI for Tidal music streaming service, designed for LLM agent automation",
  "main": "dist/index.js",
  "bin": {
    "tidal-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tidal",
    "music",
    "cli",
    "streaming",
    "llm",
    "agent",
    "automation",
    "openclaw",
    "playlist",
    "hifi"
  ],
  "author": "Luca Perret",
  "license": "MIT",
  "homepage": "https://github.com/lucaperret/tidal-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucaperret/tidal-cli.git"
  },
  "bugs": {
    "url": "https://github.com/lucaperret/tidal-cli/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@tidal-music/api": "^0.9.1",
    "@tidal-music/auth": "^1.4.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
